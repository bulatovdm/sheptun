# Sheptun configuration

# Speech recognizer: whisper or apple
SHEPTUN_RECOGNIZER=whisper

# Apple Speech locale: ru-RU, en-US, etc (only for apple)
SHEPTUN_APPLE_LOCALE=ru-RU

# Whisper model: tiny, base, small, medium, large (only for whisper)
SHEPTUN_MODEL=base

# Device for Whisper: cpu, cuda, or leave empty for auto (only for whisper)
SHEPTUN_DEVICE=

# Voice Activity Detection
SHEPTUN_VAD_TYPE=energy
SHEPTUN_ENERGY_THRESHOLD=0.01
SHEPTUN_SILENCE_DURATION=0.5
SHEPTUN_MIN_SPEECH_DURATION=0.2
SHEPTUN_MAX_SPEECH_DURATION=30.0
SHEPTUN_IDLE_TIMEOUT=5.0

# Hotkeys (menubar app)
SHEPTUN_HOTKEY_TOGGLE=<ctrl>+<alt>+s
SHEPTUN_HOTKEY_PTT=<ctrl>+<alt>+<space>

# Debug mode
SHEPTUN_DEBUG=false

# Log file path (relative to current directory or absolute)
SHEPTUN_LOG_FILE=logs/sheptun.log

# macOS app path for install-app command
SHEPTUN_APP_PATH=/Applications/Sheptun.app

# Text input method: true = clipboard (Cmd+V), false = CGEvent
SHEPTUN_USE_CLIPBOARD=false

# Delay between key events in seconds (low values may cause text duplication)
SHEPTUN_KEY_DELAY=0.02

# Warmup interval in seconds to keep model in GPU memory (0 to disable)
SHEPTUN_WARMUP_INTERVAL=120

# Claude model for transcript verification (uses Claude Agent SDK / Max subscription)
# Leave empty for Agent SDK default model
SHEPTUN_VERIFY_MODEL=claude-haiku-4-5-20251001

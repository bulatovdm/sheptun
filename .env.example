# Sheptun configuration

# Recognizer: whisper, mlx, apple, parakeet or qwen
SHEPTUN_RECOGNIZER=mlx

# Apple Speech locale: ru-RU, en-US, etc (only for apple)
SHEPTUN_APPLE_LOCALE=ru-RU

# Whisper model: tiny, base, small, medium, large, turbo
SHEPTUN_MODEL=turbo

# Device for Whisper: cpu, cuda, or leave empty for auto (only for whisper)
SHEPTUN_DEVICE=

# Initial prompt for Whisper (context hint for better domain term recognition)
# SHEPTUN_INITIAL_PROMPT=Здравствуйте. Открой терминал. git commit push pull docker pytest

# Voice Activity Detection
# VAD type: energy (default) or silero (neural network, requires pip install -e ".[silero]")
SHEPTUN_VAD_TYPE=silero
SHEPTUN_ENERGY_THRESHOLD=0.02
SHEPTUN_SILENCE_DURATION=0.3
SHEPTUN_MIN_SPEECH_DURATION=0.2
SHEPTUN_MAX_SPEECH_DURATION=30.0
SHEPTUN_IDLE_TIMEOUT=5.0

# Hotkeys (menubar app)
SHEPTUN_HOTKEY_TOGGLE=<ctrl>+<alt>+s
SHEPTUN_HOTKEY_PTT=<ctrl>+<alt>+<space>

# Debug mode
SHEPTUN_DEBUG=true

# Log file path (relative to current directory or absolute)
SHEPTUN_LOG_FILE=logs/sheptun.log

# macOS app path for install-app command
SHEPTUN_APP_PATH=/Applications/Sheptun.app

# Dataset recording for fine-tuning
SHEPTUN_RECORD_DATASET=true
SHEPTUN_DATASET_PATH=dataset

# Text input method: true = clipboard (Cmd+V), false = CGEvent
SHEPTUN_USE_CLIPBOARD=false

# Delay between key events in seconds (low values may cause text duplication)
SHEPTUN_KEY_DELAY=0.015

# Warmup interval in seconds to keep model in GPU memory (0 to disable)
SHEPTUN_WARMUP_INTERVAL=120

# Remote text delivery (Universal Control)
# SHEPTUN_REMOTE_ENABLED=false     # Send text to remote machine
# SHEPTUN_REMOTE_SERVE=false       # Accept text from remote (server mode)
# SHEPTUN_REMOTE_HOST=             # Remote host (empty = Bonjour discovery)
# SHEPTUN_REMOTE_PORT=7849         # Remote server port
# SHEPTUN_REMOTE_TOKEN=            # Shared secret for auth
# SHEPTUN_REMOTE_AUTO_DETECT=true  # Auto-detect by cursor position

# Fine-tuning Whisper
SHEPTUN_FINETUNE_MODEL=large             # Базовая модель (tiny/base/small/medium/large)
SHEPTUN_FINETUNE_METHOD=lora             # Метод обучения (lora, full)
SHEPTUN_FINETUNE_STEPS=4000              # Количество шагов обучения
SHEPTUN_FINETUNE_BATCH_SIZE=4            # Размер батча
SHEPTUN_FINETUNE_LR=1e-5                 # Learning rate
SHEPTUN_FINETUNE_WARMUP_STEPS=500        # Шаги warmup
SHEPTUN_FINETUNE_OUTPUT=models/whisper-sheptun  # Куда сохранять
SHEPTUN_FINETUNE_MIN_CONFIDENCE=medium   # Минимальный confidence из verification.db

# Anthropic SDK для анализа логов (команда: sheptun analyze-replacements)
# Требует установки: pip install -e ".[llm]"
# SHEPTUN_ANTHROPIC_BASE_URL=            # Кастомный base_url (пусто = api.anthropic.com)
# SHEPTUN_ANTHROPIC_API_KEY=            # API-ключ (пусто = берётся из ANTHROPIC_API_KEY)

# Анализатор логов → предложения автозамен
SHEPTUN_ANALYZER_MODEL=claude-opus-4-8   # Модель Anthropic
SHEPTUN_ANALYZER_CONTEXT_LINES=10        # Контекст ±N строк вокруг каждой строки
SHEPTUN_ANALYZER_BATCH_SIZE=20           # Окон в одном запросе к модели
SHEPTUN_ANALYZER_MAX_WINDOWS=0           # Лимит окон (0 = без лимита)
SHEPTUN_ANALYZER_MIN_FREQ=1              # Минимальная частота строки для анализа (1 = анализировать всё)
SHEPTUN_ANALYZER_EFFORT=high             # Уровень усилий модели (low/medium/high/xhigh/max)
SHEPTUN_ANALYZER_MIN_CONFIDENCE=medium   # Отсекать кандидатов ниже уровня (low/medium/high)
SHEPTUN_ANALYZER_MAX_ITERATIONS=0        # Лимит запросов к модели за прогон (0 = без лимита)
SHEPTUN_ANALYZER_VERIFY=true             # Второй проход-критик перепроверяет кандидатов (доп. запрос)
SHEPTUN_ANALYZER_MAX_RETRIES=0           # Ретраи SDK на запрос (0 = свой backoff-цикл ниже управляет повторами)
SHEPTUN_ANALYZER_DELAY=0.5               # Пауза (сек) между запросами к модели — щадит прокси
SHEPTUN_ANALYZER_RETRY_BACKOFF=15        # При ошибке ждать backoff×попытка сек (15,30,45,60) и повторить батч
SHEPTUN_ANALYZER_MAX_ERROR_RETRIES=4     # Сколько раз повторять сбойный батч до выхода из прогона
# Некоторые прокси блокируют стандартный User-Agent SDK; переопредели при необходимости
# SHEPTUN_ANALYZER_USER_AGENT=

# Sheptun configuration

# Recognizer: whisper, mlx or apple
SHEPTUN_RECOGNIZER=mlx

# Apple Speech locale: ru-RU, en-US, etc (only for apple)
SHEPTUN_APPLE_LOCALE=ru-RU

# Whisper model: tiny, base, small, medium, large, turbo
SHEPTUN_MODEL=turbo

# Device for Whisper: cpu, cuda, or leave empty for auto (only for whisper)
SHEPTUN_DEVICE=

# Voice Activity Detection
# VAD type: energy (default) or silero (neural network, requires pip install -e ".[silero]")
SHEPTUN_VAD_TYPE=silero
SHEPTUN_ENERGY_THRESHOLD=0.02
SHEPTUN_SILENCE_DURATION=0.3
SHEPTUN_MIN_SPEECH_DURATION=0.2
SHEPTUN_MAX_SPEECH_DURATION=30.0
SHEPTUN_IDLE_TIMEOUT=5.0

# Hotkeys (menubar app)
SHEPTUN_HOTKEY_TOGGLE=<ctrl>+<alt>+s
SHEPTUN_HOTKEY_PTT=<ctrl>+<alt>+<space>

# Debug mode
SHEPTUN_DEBUG=true

# Log file path (relative to current directory or absolute)
SHEPTUN_LOG_FILE=logs/sheptun.log

# macOS app path for install-app command
SHEPTUN_APP_PATH=/Applications/Sheptun.app

# Dataset recording for fine-tuning
SHEPTUN_RECORD_DATASET=true
SHEPTUN_DATASET_PATH=dataset

# Text input method: true = clipboard (Cmd+V), false = CGEvent
SHEPTUN_USE_CLIPBOARD=false

# Delay between key events in seconds (low values may cause text duplication)
SHEPTUN_KEY_DELAY=0.015

# Warmup interval in seconds to keep model in GPU memory (0 to disable)
SHEPTUN_WARMUP_INTERVAL=120

# Claude model for transcript verification (uses Claude Agent SDK / Max subscription)
SHEPTUN_VERIFY_MODEL=claude-haiku-4-5-20251001

# Parallel requests for verification (1 = sequential, max 10)
SHEPTUN_VERIFY_CONCURRENCY=8

# Fine-tuning Whisper
SHEPTUN_FINETUNE_MODEL=large             # Базовая модель (tiny/base/small/medium/large)
SHEPTUN_FINETUNE_METHOD=lora             # Метод обучения (lora, full)
SHEPTUN_FINETUNE_STEPS=4000              # Количество шагов обучения
SHEPTUN_FINETUNE_BATCH_SIZE=4            # Размер батча
SHEPTUN_FINETUNE_LR=1e-5                 # Learning rate
SHEPTUN_FINETUNE_WARMUP_STEPS=500        # Шаги warmup
SHEPTUN_FINETUNE_OUTPUT=models/whisper-sheptun  # Куда сохранять
SHEPTUN_FINETUNE_MIN_CONFIDENCE=medium   # Минимальный confidence из verification.db
